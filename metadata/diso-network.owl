        <void:subset rdf:resource="https://city-artificial-intelligence.github.io/diso/dataset/ontology/CPE"/>
        <void:subset rdf:resource="https://city-artificial-intelligence.github.io/diso/dataset/ontology/CVE"/>
        <void:subset rdf:resource="https://city-artificial-intelligence.github.io/diso/dataset/ontology/CVSS"/>
        <void:subset rdf:resource="https://city-artificial-intelligence.github.io/diso/dataset/ontology/CWE"/>
        <void:subset rdf:resource="https://city-artificial-intelligence.github.io/diso/dataset/ontology/D3FEND"/>
        <void:subset rdf:resource="https://city-artificial-intelligence.github.io/diso/dataset/ontology/ICS-SEC-KG-ONTO"/>
        <void:subset rdf:resource="https://city-artificial-intelligence.github.io/diso/dataset/ontology/ICSA"/>
        <void:subset rdf:resource="https://city-artificial-intelligence.github.io/diso/dataset/ontology/ITIO"/>
