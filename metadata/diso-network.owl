        <void:subset rdf:resource="https://city-artificial-intelligence.github.io/diso/dataset/ontology/UCO_1"/>
        <void:subset rdf:resource="https://city-artificial-intelligence.github.io/diso/dataset/ontology/UCO_2"/>
        <rdfs:label>Cyber Security</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://city-artificial-intelligence.github.io/diso/dataset/cluster/digital-twins -->

    <owl:NamedIndividual rdf:about="https://city-artificial-intelligence.github.io/diso/dataset/cluster/digital-twins">
        <rdf:type rdf:resource="https://city-artificial-intelligence.github.io/diso/ontology#Cluster"/>
