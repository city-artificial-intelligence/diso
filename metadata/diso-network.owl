    <!-- https://city-artificial-intelligence.github.io/diso/dataset/cluster/agentic -->

    <owl:NamedIndividual rdf:about="https://city-artificial-intelligence.github.io/diso/dataset/cluster/agentic">
        <rdf:type rdf:resource="https://city-artificial-intelligence.github.io/diso/ontology#Cluster"/>
        <dcterms:description>Ontologies relating to agentic AI and (semantic) services.</dcterms:description>
        <dcterms:title>Agentic</dcterms:title>
        <void:subset rdf:resource="https://city-artificial-intelligence.github.io/diso/dataset/ontology/OWL-S"/>
        <rdfs:label>Agentic</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://city-artificial-intelligence.github.io/diso/dataset/cluster/ambient-intelligence -->

    <owl:NamedIndividual rdf:about="https://city-artificial-intelligence.github.io/diso/dataset/cluster/ambient-intelligence">
        <rdf:type rdf:resource="https://city-artificial-intelligence.github.io/diso/ontology#Cluster"/>
        <dcterms:description>Environments with electronic devices that are aware of and adapt to human presence, enhancing interaction through context-aware, interconnected systems.</dcterms:description>
        <dcterms:title>Ambient Intelligence</dcterms:title>
        <void:subset rdf:resource="https://city-artificial-intelligence.github.io/diso/dataset/ontology/BOnSAI"/>
        <rdfs:label>Ambient Intelligence</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://city-artificial-intelligence.github.io/diso/dataset/cluster/context-awareness -->

    <owl:NamedIndividual rdf:about="https://city-artificial-intelligence.github.io/diso/dataset/cluster/context-awareness">
        <rdf:type rdf:resource="https://city-artificial-intelligence.github.io/diso/ontology#Cluster"/>
        <dcterms:description>A special case of situation awareness focused on individuals and their immediate context, supporting pervasive computing where services adapt to user context.</dcterms:description>
        <dcterms:title>Context Awareness</dcterms:title>
        <void:subset rdf:resource="https://city-artificial-intelligence.github.io/diso/dataset/ontology/CoDAMoS"/>
        <void:subset rdf:resource="https://city-artificial-intelligence.github.io/diso/dataset/ontology/SOUPA"/>
        <void:subset rdf:resource="https://city-artificial-intelligence.github.io/diso/dataset/ontology/mIO"/>
        <rdfs:label>Context Awareness</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://city-artificial-intelligence.github.io/diso/dataset/cluster/cyber-security -->

    <owl:NamedIndividual rdf:about="https://city-artificial-intelligence.github.io/diso/dataset/cluster/cyber-security">
        <rdf:type rdf:resource="https://city-artificial-intelligence.github.io/diso/ontology#Cluster"/>
        <dcterms:description>Information security strictly within the digital domain: securing assets against digital threats. The largest cluster in DISO.</dcterms:description>
        <dcterms:title>Cyber Security</dcterms:title>
