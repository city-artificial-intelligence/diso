    <!-- http://rdfs.org/ns/void#Dataset -->

    <owl:Class rdf:about="http://rdfs.org/ns/void#Dataset"/>
    


    <!-- https://city-artificial-intelligence.github.io/diso/ontology#Cluster -->

    <owl:Class rdf:about="https://city-artificial-intelligence.github.io/diso/ontology#Cluster">
        <rdfs:subClassOf rdf:resource="http://rdfs.org/ns/void#Dataset"/>
        <rdfs:comment>A subdomain grouping (cluster) within an ontology network. Its void:subset members are member ontologies, or - for a grouping cluster - further sub-clusters.</rdfs:comment>
        <rdfs:label>Cluster</rdfs:label>
    </owl:Class>
    


    <!-- https://city-artificial-intelligence.github.io/diso/ontology#MemberOntology -->

    <owl:Class rdf:about="https://city-artificial-intelligence.github.io/diso/ontology#MemberOntology">
        <rdfs:subClassOf rdf:resource="http://rdfs.org/ns/void#Dataset"/>
        <rdfs:comment>An individual ontology that is a member of the network, described as a VoID dataset.</rdfs:comment>
        <rdfs:label>Member Ontology</rdfs:label>
    </owl:Class>
    


    <!-- https://city-artificial-intelligence.github.io/diso/ontology#OntologyNetwork -->

    <owl:Class rdf:about="https://city-artificial-intelligence.github.io/diso/ontology#OntologyNetwork">
        <rdfs:subClassOf rdf:resource="http://rdfs.org/ns/void#Dataset"/>
        <rdfs:comment>A curated network (collection) of ontologies, described as a VoID dataset whose void:subset members are its clusters. DISO itself is the sole instance.</rdfs:comment>
        <rdfs:label>Ontology Network</rdfs:label>
    </owl:Class>
