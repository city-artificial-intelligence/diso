     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:diso="https://city-artificial-intelligence.github.io/diso/ontology#"
     xmlns:foaf="http://xmlns.com/foaf/0.1/"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:void="http://rdfs.org/ns/void#"
     xmlns:dcterms="http://purl.org/dc/terms/">
    <owl:Ontology rdf:about="https://city-artificial-intelligence.github.io/diso/ontology">
        <dcterms:creator rdf:resource="https://orcid.org/0009-0009-0260-0492"/>
        <dcterms:description>A small OWL vocabulary for describing DISO (Defence, Intelligence and Security Ontologies) as a VoID / Dublin Core network of ontologies. It specialises void:Dataset into the ontology network, its subdomain clusters, and its member ontologies. Descriptive metadata reuses Dublin Core Terms and VoID terms directly.</dcterms:description>
        <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-05-07</dcterms:issued>
        <dcterms:license rdf:resource="https://spdx.org/licenses/MIT"/>
        <dcterms:publisher>City St George&apos;s, University of London</dcterms:publisher>
        <dcterms:title>The DISO Vocabulary</dcterms:title>
        <rdfs:seeAlso rdf:resource="https://github.com/city-artificial-intelligence/diso"/>
        <owl:versionInfo>1.0.0</owl:versionInfo>
    </owl:Ontology>
    


