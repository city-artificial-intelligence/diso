     xmlns:diso="https://city-artificial-intelligence.github.io/diso/ontology#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:void="http://rdfs.org/ns/void#"
     xmlns:dcterms="http://purl.org/dc/terms/">
    <owl:Ontology rdf:about="https://city-artificial-intelligence.github.io/diso/dataset">
        <owl:imports rdf:resource="https://city-artificial-intelligence.github.io/diso/ontology"/>
        <dcterms:description>DISO (defence, intelligence and security ontologies) Network - the network of defence, intelligence and security ontologies - its subdomain clusters and its member ontologies.</dcterms:description>
        <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-05-07</dcterms:issued>
        <dcterms:title>DISO (defence, intelligence and security ontologies) Network</dcterms:title>
        <owl:versionInfo>1.0.0</owl:versionInfo>
    </owl:Ontology>
    


