        <void:subset rdf:resource="https://city-artificial-intelligence.github.io/diso/dataset/ontology/MDISOnt"/>
        <void:subset rdf:resource="https://city-artificial-intelligence.github.io/diso/dataset/ontology/OntoSecRPA"/>
        <void:subset rdf:resource="https://city-artificial-intelligence.github.io/diso/dataset/ontology/SO"/>
        <void:subset rdf:resource="https://city-artificial-intelligence.github.io/diso/dataset/ontology/SecAOnto"/>
        <rdfs:label>Information Security</rdfs:label>
    </owl:NamedIndividual>
    


