        <rdf:type rdf:resource="https://city-artificial-intelligence.github.io/diso/ontology#Cluster"/>
        <dcterms:description>Protecting information in all forms, physical and digital, around the CIA triad of confidentiality, integrity and availability.</dcterms:description>
