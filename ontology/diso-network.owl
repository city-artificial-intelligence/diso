        <rdf:type rdf:resource="https://city-artificial-intelligence.github.io/diso/ontology#Cluster"/>
        <dcterms:description>Ontologies that standardise data representations to facilitate the exchange and aggregation of data across diverse domains, organisations and systems.</dcterms:description>
        <dcterms:title>Information Exchange</dcterms:title>
        <void:subset rdf:resource="https://city-artificial-intelligence.github.io/diso/dataset/ontology/IES"/>
        <void:subset rdf:resource="https://city-artificial-intelligence.github.io/diso/dataset/ontology/JC3IEDM"/>
        <rdfs:label>Information Exchange</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://city-artificial-intelligence.github.io/diso/dataset/cluster/information-security -->

