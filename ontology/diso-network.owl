<?xml version="1.0"?>
<rdf:RDF xmlns="https://city-artificial-intelligence.github.io/diso/dataset#"
     xml:base="https://city-artificial-intelligence.github.io/diso/dataset"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
